		}, {
			"keys": "alt+v", "id": "Terminal.SplitPaneLeft"
		}, {
			"keys": "alt+w", "id": "Terminal.QuickPaneDown"
		}, {
			"keys": "alt+x", "id": "Terminal.ClosePane"
		}, {
			"keys": "alt+y", "id": "Terminal.CopyMode"
		}, {
			"keys": "ctrl+shift+c", "id": "Terminal.CopyToClipboard"
		}, {
			"keys": "ctrl+shift+f", "id": "Terminal.FindText"
		}, {
			"keys": "ctrl+shift+v", "id": "Terminal.PasteFromClipboard"
		}
	],
